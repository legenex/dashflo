{
  "name": "DashboardLayout",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "default": "Overview"
    },
    "widget_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "owner_id": {
      "type": "string",
      "description": "User ID this layout belongs to"
    }
  },
  "required": [
    "owner_id"
  ]
}