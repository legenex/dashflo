# DashFlo environment. Copy to .env and adjust. Every variable is optional
# in local development, sensible defaults keep the app fully functional.

# Postgres connection string. When set and reachable, DashFlo uses Postgres.
# When absent (or the server is down), DashFlo falls back to embedded PGlite
# stored in ./.data/pglite so `pnpm setup && pnpm dev` works with no Docker.
# docker-compose.yml provides a matching server: postgres://dashflo:dashflo@localhost:5433/dashflo
DATABASE_URL=

# Auth.js session encryption secret. A stable dev default is used when unset.
AUTH_SECRET=

# Anthropic API key for the AI analyst (model claude-sonnet-4-6).
# When unset, the deterministic local intent router answers over the same
# tool layer and the UI labels answers "Local analysis mode".
ANTHROPIC_API_KEY=

# Base URL the app uses to build ingest URLs and docs cURL examples.
NEXT_PUBLIC_APP_URL=http://localhost:4780

# Mock buyer server (started automatically by `pnpm dev`).
MOCKBUYER_PORT=4010

# Meta CAPI: when a token is set, events post to Meta. When empty, the local
# mock mode logs the exact outbound payloads to the event log instead.
META_CAPI_TOKEN=

# Slack incoming webhook used by automations. When empty, Slack actions log
# to the console and the Notifications bell instead of posting.
SLACK_WEBHOOK_URL=
